   ],
   "source": [
    "X = sm.add_constant(data_sorted['Inverse_Temp'])  # Predictor Variable (Inverse Temperature)\n",
    "#Y = data_sorted['Ln_Mpa']  # Response Variable (Log of Mpa)\n",
    "Y = np.log(scale)\n",
    "# Fit Weibull Regression Model using MLE\n",
    "model = sm.OLS(Y, X).fit()\n",
    "print(model.summary())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "99504f4e-9a7f-4fcc-b74e-24b3d2f3bce5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Intercept (u): 3.7091\n",
      "Weibull Shape Parameter (m): 6.1544\n",
      "Inverse Temperature Coefficient (w): 0.0654\n",
      "location parameter (g): 417.6733\n"
     ]
    }
   ],
   "source": [
    "u = model.params.iloc[0]\n",
    "m = shape_3p\n",
    "w = model.params.iloc[1]\n",
    "g = gamma_3p\n",
    "\n",
    "print(f\"Intercept (u): {u:.4f}\")\n",
    "print(f\"Weibull Shape Parameter (m): {m:.4f}\")\n",
    "print(f\"Inverse Temperature Coefficient (w): {w:.4f}\")\n",
    "print(f\"location parameter (g): {g:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "f3d0c250-0745-44bd-8a93-26040a1222c5",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "temperature_values = np.linspace(10, 600, 100)\n",
    "\n",
    "# Assume mean shape for prediction\n",
    "shape = m\n",
    "intercept = u\n",
    "slope = w\n",
    "loc = g\n",
    "# cdf\n",
    "cdf_50 = 0.5\n",
    "cdf_90 = 0.9\n",
    "cdf_10 = 0.1\n",
    "cdf_99 = 0.99\n",
    "cdf_01 = 0.01\n",
    "\n",
    "ys_predicted_cdf_50 = loc + np.exp(\n",
    "    (intercept + (slope * 11604.53 / (temperature_values + 273.16))) +\n",
    "    ((1 / shape) * np.log(np.log(1 / (1 - cdf_50))))\n",
    ")\n",
    "\n",
    "ys_predicted_cdf_90 = loc + np.exp(\n",
    "    (intercept + (slope * 11604.53 / (temperature_values + 273.16))) +\n",
    "    ((1 / shape) * np.log(np.log(1 / (1 - cdf_90))))\n",
    ")\n",
    "\n",
    "ys_predicted_cdf_10 = loc + np.exp(\n",
    "    (intercept + (slope * 11604.53 / (temperature_values + 273.16))) +\n",
    "    ((1 / shape) * np.log(np.log(1 / (1 - cdf_10))))\n",
    ")\n",
    "\n",
    "ys_predicted_cdf_99 = loc + np.exp(\n",
    "    (intercept + (slope * 11604.53 / (temperature_values + 273.16))) +\n",
    "    ((1 / shape) * np.log(np.log(1 / (1 - cdf_99))))\n",
    ")\n",
    "\n",
    "ys_predicted_cdf_01 = loc + np.exp(\n",
    "    (intercept + (slope * 11604.53 / (temperature_values + 273.16))) +\n",
    "    ((1 / shape) * np.log(np.log(1 / (1 - cdf_01))))\n",
    ")\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "\n",
    "# Scatter plots\n",
    "plt.scatter(df_1[\"Temperature\"], df_1[\"Mpa\"], color='royalblue', edgecolors='black', alpha=0.7, s=80, label=\"Vendor 1\")\n",
    "plt.scatter(df_2[\"Temperature\"], df_2[\"Mpa\"], marker='*', color='darkorange', edgecolors='black', alpha=0.7, s=80, label=\"Vendor 2\")\n",
    "\n",
    "# predicted YS curves\n",
    "plt.plot(temperature_values, ys_predicted_cdf_50, color=\"red\", linestyle=\"-\", linewidth=2, label=\"Predicted YS (CDF=0.50)\")\n",
    "plt.plot(temperature_values, ys_predicted_cdf_90, color=\"blue\", linestyle=\"-\", linewidth=2, label=\"Predicted YS (CDF=0.90)\")\n",
    "plt.plot(temperature_values, ys_predicted_cdf_10, color=\"orange\", linestyle=\"-\", linewidth=2, label=\"Predicted YS (CDF=0.10)\")\n",
    "plt.plot(temperature_values, ys_predicted_cdf_99, color=\"green\", linestyle=\"-\", linewidth=2, label=\"Predicted YS (CDF=0.99)\")\n",
    "plt.plot(temperature_values, ys_predicted_cdf_01, color=\"purple\", linestyle=\"-\", linewidth=2, label=\"Predicted YS (CDF=0.01)\")\n",
    "\n",
    "plt.xlabel(\"Temperature (°C)\", fontsize=12, fontweight=\"bold\")\n",
    "plt.ylabel(\"Yield Stress (YS)\", fontsize=12, fontweight=\"bold\")\n",
    "plt.title(\"Yield Stress vs. Temperature Comparison\", fontsize=14, fontweight=\"bold\")\n",
    "\n",
    "plt.grid(True, linestyle='--', alpha=0.6)\n",
    "plt.legend(fontsize=12)\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "56ab2fe6-b272-4164-a63a-14473c40432b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "CONSTANT_SHAPE = m\n",
    "\n",
    "# Median rank function (Benard's formula)\n",
    "def median_rank(n, i):\n",
    "    return (i - 0.3) / (n + 0.4)\n",
    "\n",
    "# Create Weibull probability plot with 3-parameter model\n",
    "plt.figure(figsize=(10, 6))\n",
    "\n",
    "for temp in df_dict.keys():\n",
    "    data = df_dict[temp][\"Mpa\"].values\n",
    "    data = np.sort(data)\n",
    "\n",
    "    n = len(data)\n",
    "    p_values = np.array([median_rank(n, i + 1) for i in range(n)])\n",
    "\n",
    "    # Fit 3-parameter Weibull with fixed shape\n",
    "    shape = CONSTANT_SHAPE\n",
    "    shape_fixed = shape\n",
    "    shape_fixed, loc, scale = stats.weibull_min.fit(data, f0=shape)\n",
    "\n",
    "    # Filter values greater than loc to ensure positive adjusted_x\n",
    "    valid_mask = data > loc\n",
    "    data_adj = data[valid_mask]\n",
    "    p_adj = p_values[valid_mask]\n",
    "\n",
    "    # Weibull probability transform\n",
    "    x_values = np.log(data_adj - loc)\n",
    "    y_values = np.log(-np.log(1 - p_adj))\n",
    "\n",
    "    # Scatter plot of transformed data\n",
    "    plt.scatter(x_values, y_values, label=f\"Temp {temp}\")\n",
    "\n",
    "    # Fitted line\n",
    "    x_fit = np.linspace(min(data_adj), max(data_adj), 100)\n",
    "    y_fit = np.log(-np.log(1 - stats.weibull_min.cdf(x_fit, shape, loc=loc, scale=scale)))\n",
    "    plt.plot(np.log(x_fit - loc), y_fit, linestyle='-', label=f\"Fitted Line - Temp {temp}\")\n",
    "\n",
    "# Axis labels and title\n",
    "plt.title(\"3-Parameter Weibull Probability Plot (Constant Shape)\")\n",
    "plt.xlabel(\"ln(Data - γ)\")\n",
    "plt.ylabel(\"ln(-ln(1 - p))\")\n",
    "plt.legend()\n",
    "plt.grid()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
