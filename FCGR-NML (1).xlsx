   "source": [
    "df_dict = {temp: df_3[df_3[\"Temperature\"] == temp].reset_index(drop=True) for temp in df_3[\"Temperature\"].unique()}\n",
    "\n",
    "df_dict[550]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "d2b4abc4-79b4-47a7-a480-0411b233c9e8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Arrhenius Transform\n",
    "data_sorted['Inverse_Temp'] = 11604.53 / (data_sorted['Temperature'] + 273.16)  # Convert to Kelvin\n",
    "data_sorted['Ln_Mpa'] = np.log(data_sorted['Mpa'])  # Log transformation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "89ac6243-e6d7-4372-a50b-fb95364fc638",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_values = data_sorted['Inverse_Temp'].values\n",
    "Y_values = data_sorted['Mpa'].values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "021996b2-6f5a-4e0f-b048-b4c04dd4a714",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[3-Parameter Fit] Shape: 6.1544, Gamma: 417.6733\n"
     ]
    }
   ],
   "source": [
    "# 3-parameter Weibull log-likelihood function\n",
    "def weibull_3p_log_likelihood(params, x, y):\n",
    "    shape = params[0]\n",
    "    beta0 = params[1]\n",
    "    beta1 = params[2]\n",
    "    gamma = params[3]\n",
    "    \n",
    "    if shape <= 0 or np.any(y - gamma <= 0):\n",
    "        return np.inf\n",
    "    \n",
    "    scale = np.exp(beta0 + beta1 * x)\n",
    "    adjusted_y = y - gamma\n",
    "\n",
    "    return -np.sum(stats.weibull_min.logpdf(adjusted_y, c=shape, scale=scale))\n",
    "\n",
    "# Initial guess: [shape, β0, β1, gamma]\n",
    "init_params_3p = [2.0, np.log(np.mean(Y_values)), 0.0, np.min(Y_values) * 0.9]\n",
    "bounds_3p = [(1e-6, None), (None, None), (None, None), (None, np.min(Y_values) - 1e-6)]\n",
    "\n",
    "result_3p = optimize.minimize(\n",
    "    weibull_3p_log_likelihood,\n",
    "    init_params_3p,\n",
    "    args=(X_values, Y_values),\n",
    "    bounds=bounds_3p,\n",
    "    method='L-BFGS-B'\n",
    ")\n",
    "\n",
    "shape_3p, beta0_3p, beta1_3p, gamma_3p = result_3p.x\n",
    "print(f\"[3-Parameter Fit] Shape: {shape_3p:.4f}, Gamma: {gamma_3p:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "6b853ab0-6a5a-49c5-addf-486c0e66b2bf",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Intercept (u): 3.709074\n",
      "Slope (w): 0.065406\n"
     ]
    }
   ],
   "source": [
    "# Sample data (Replace with actual values)\n",
    "X = data_sorted['Inverse_Temp'].values  # Predictor variable\n",
    "scale = np.exp(beta0_3p + beta1_3p * X)\n",
    "\n",
    "Y = np.log(scale)\n",
    "# Compute means\n",
    "X_mean = sum(X) / len(X)\n",
    "Y_mean = sum(Y) / len(Y)\n",
    "\n",
    "# Compute slope\n",
    "numerator = sum((X[i] - X_mean) * (Y[i] - Y_mean) for i in range(len(X)))\n",
    "denominator = sum((X[i] - X_mean) ** 2 for i in range(len(X)))\n",
    "w = numerator / denominator\n",
    "\n",
    "# Compute intercept\n",
    "u = Y_mean - w * X_mean\n",
    "\n",
    "# Display results\n",
    "print(f\"Intercept (u): {u:.6f}\")\n",
    "print(f\"Slope (w): {w:.6f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "d4a62323-8512-41ce-bef1-f2f03b0faf32",
   "metadata": {},
