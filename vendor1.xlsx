   "source": [
    "data = pd.concat([df_1, df_2], ignore_index=True)\n",
    "data_sorted = data.sort_values(by=\"Temperature\", ascending=True)\n",
    "df_3 = data_sorted.reset_index(drop=True)\n",
    "df_3.head(10)"
   ]
